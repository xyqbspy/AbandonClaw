# 复制本文件为 .env.local 并替换 __REPLACE_ME__ 为真实值。
# 所有 __REPLACE_ME__ 标记的字段都是 secret，不要 commit 到 git。
# 不要把真实 secret 写入本模板。模板中只允许出现占位符或非敏感默认值。

# ============================================================================
# 模型上游（必填）
# ============================================================================

# GLM API key；从 GLM provider 后台获取，泄露后会直接产生外部账单成本
GLM_API_KEY=__REPLACE_ME__
# GLM 调用入口；默认走官方端点
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM 模型版本；按 provider 实际可用版本配置
GLM_MODEL=glm-4.6

# ============================================================================
# Supabase（必填）
# ============================================================================

# Supabase 项目 URL；可在 Supabase 后台 Project Settings → API 查看
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase anon key；前端使用，可公开
NEXT_PUBLIC_SUPABASE_ANON_KEY=__REPLACE_ME__
# Supabase service role key；可绕过 RLS 操作整库，仅服务端使用，绝不可暴露到客户端
SUPABASE_SERVICE_ROLE_KEY=__REPLACE_ME__

# ============================================================================
# 应用域名与管理员（必填）
# ============================================================================

# 管理员邮箱白名单，逗号分隔；用于 /admin 后台访问控制
ADMIN_EMAILS=admin@example.com
# 应用对外域名；用于 Origin 校验与邮件验证回跳
APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================================
# 邮箱发送与验证码（公网注册必填）
# ============================================================================

# Resend API key；用于发送注册验证码邮件
RESEND_API_KEY=__REPLACE_ME__
# 验证码发件邮箱；需在 Resend 后台完成域名 DNS 验证（SPF/DKIM）
EMAIL_FROM=noreply@example.com
# 验证码签名密钥；至少 32 字符的随机字符串，用于防止伪造验证码
EMAIL_VERIFICATION_CODE_SECRET=__REPLACE_ME__

# ============================================================================
# 注册模式与频控（公网注册建议配置）
# ============================================================================

# 注册模式：closed / invite_only / open；默认 closed
# 公网小范围开放推荐 invite_only；任何不可控渠道发布前不要切到 open
REGISTRATION_MODE=closed
# 同一 IP 注册尝试上限；保守默认 3
REGISTRATION_IP_LIMIT_MAX_ATTEMPTS=3
# 同一 IP 注册频控窗口（秒）；保守默认 600
REGISTRATION_IP_LIMIT_WINDOW_SECONDS=600

# ============================================================================
# 限流（公网部署强烈建议配置 Upstash）
# ============================================================================

# Upstash Redis REST URL；缺失时回退到进程内存限流，不能覆盖多实例部署
UPSTASH_REDIS_REST_URL=__REPLACE_ME__
UPSTASH_REDIS_REST_TOKEN=__REPLACE_ME__

# ============================================================================
# 高成本接口每日额度（可选；缺失时使用服务端保守默认值）
# ============================================================================

# 每用户每日额度上限；超过返回 429，不会触发上游模型/TTS
# DAILY_QUOTA_PRACTICE_GENERATE=20
# DAILY_QUOTA_SCENE_GENERATE=8
# DAILY_QUOTA_SIMILAR_GENERATE=20
# DAILY_QUOTA_EXPRESSION_MAP_GENERATE=20
# DAILY_QUOTA_EXPLAIN_SELECTION=30
# DAILY_QUOTA_TTS_GENERATE=80
# DAILY_QUOTA_TTS_REGENERATE=12

# ============================================================================
# 上游调用与存储（可选）
# ============================================================================

# 上游模型/TTS 调用超时（毫秒）；默认值在 src/lib/server/upstream.ts
# UPSTREAM_FETCH_TIMEOUT_MS=30000
# TTS 音频对象存储 bucket 名称；默认走 Supabase storage
# TTS_STORAGE_BUCKET=tts-audio

# ============================================================================
# 备用 explain provider（可选）
# ============================================================================

# 切换到 OpenAI 作为 explain 兜底时使用
# EXPLAIN_PROVIDER=openai
# OPENAI_API_KEY=__REPLACE_ME__
# OPENAI_EXPLAIN_MODEL=gpt-4o-mini
