{
  "name": "abandon-en",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "pnpm run test:unit",
    "test:unit": "node --import tsx --test src/**/*.test.ts",
    "test:interaction": "node --import tsx --import ./src/test/setup-dom.ts --test src/**/*.test.tsx",
    "test:interaction:cache-refresh": "node --import tsx --import ./src/test/setup-dom.ts --test \"src/components/layout/pull-to-refresh.test.tsx\" \"src/app/(app)/scenes/page.interaction.test.tsx\" \"src/app/(app)/review/page.interaction.test.tsx\" \"src/app/(app)/chunks/page.interaction.test.tsx\" \"src/app/(app)/chunks/use-chunks-list-data.test.tsx\"",
    "test:interaction:scene-detail": "node --import tsx --import ./src/test/setup-dom.ts --test \"src/app/(app)/scene/[[]slug[]]/page.regression.test.tsx\"",
    "test:interaction:theme-semantic": "node --import tsx --import ./src/test/setup-dom.ts --test \"src/app/(app)/scenes/page.interaction.test.tsx\" \"src/app/(app)/chunks/page.interaction.test.tsx\" \"src/app/(app)/chunks/chunks-list-view.interaction.test.tsx\" \"src/features/chunks/components/focus-detail-actions.interaction.test.tsx\" \"src/features/chunks/components/focus-detail-content.interaction.test.tsx\" \"src/features/chunks/components/focus-detail-sheet.interaction.test.tsx\" \"src/features/chunks/components/expression-map-sheet.interaction.test.tsx\" \"src/features/chunks/components/move-into-cluster-sheet.interaction.test.tsx\" \"src/features/chunks/components/cluster-focus-list.interaction.test.tsx\" \"src/features/chunks/components/example-sentence-cards.test.tsx\" \"src/features/scene/components/scene-expression-map-view.interaction.test.tsx\" \"src/features/scene/components/scene-practice-view.interaction.test.tsx\" \"src/features/scene/components/scene-variants-view.interaction.test.tsx\" \"src/app/(app)/scene/[[]slug[]]/page.regression.test.tsx\"",
    "test:all": "pnpm run test:unit && pnpm run test:interaction",
    "text:check-mojibake": "node --import tsx scripts/check-mojibake.ts",
    "phrases:infer-relations": "npx tsx scripts/infer-missing-phrase-relations.ts",
    "phrases:backfill-relation-families": "npx tsx scripts/backfill-phrase-relation-families.ts",
    "phrases:enrich-missing": "npx tsx scripts/enrich-missing-phrases.ts",
    "scenes:repair-duplicate-sentences": "npx tsx scripts/repair-generated-scene-duplicate-sentences.ts",
    "tts:warmup": "node scripts/warmup-tts.mjs",
    "tts:warmup:scene-full": "node scripts/warmup-scene-full-tts.mjs",
    "spec:list": "openspec list --specs",
    "spec:validate": "openspec validate --specs --strict --no-interactive"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fission-ai/openspec": "^1.2.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "msedge-tts": "^2.0.4",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "aria-query": "5.3.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^26.1.0",
    "react-is": "^19.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "aria-query": "5.3.2"
    }
  }
}
