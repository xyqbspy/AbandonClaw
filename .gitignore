# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/newApphtml
/.pnp
.claude
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/public/audio/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# .env.example 是占位符模板，不能含真实 secret；允许 commit 进仓库供新人参考
!.env.example

# 根目录 HTML(简历 / 临时草稿等个人材料,不入 repo;public/ 与 src/ 下不受影响)
/*.html

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env
